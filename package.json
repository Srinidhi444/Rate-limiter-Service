  "dependencies": {
    "express": "^5.2.1",
    "redis": "^6.0.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.1",
    "shx": "^0.4.0",
    "typescript": "^6.0.3"
